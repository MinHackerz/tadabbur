generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────

enum JourneyType {
  living
  departed
  personal

  @@map("journey_type")
}

enum GoalType {
  days
  khatm
  juz
  custom

  @@map("goal_type")
}

// ── Tables ───────────────────────────────────────────────────────────

model User {
  id        String   @id @db.VarChar(255) // OIDC sub claim
  email     String?  @db.VarChar(255)
  name      String?  @db.VarChar(255)
  firstName String?  @map("first_name") @db.VarChar(255)
  lastName  String?  @map("last_name") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("users")
}

model UserNotesMeta {
  id              String   @id @db.VarChar(255)
  userId          String   @map("user_id") @db.VarChar(255)
  richTextContent String?  @map("rich_text_content")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("user_notes_meta")
}

model UserCollectionsMeta {
  id            String  @id @db.VarChar(255)
  userId        String  @map("user_id") @db.VarChar(255)
  coverImageUrl String? @map("cover_image_url") @db.VarChar(1024)

  @@map("user_collections_meta")
}

model NiyyahJourney {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String      @map("user_id") @db.VarChar(255)
  type          JourneyType
  recipientName String      @map("recipient_name")
  occasion      String
  personalDua   String      @map("personal_dua")
  goalType      GoalType    @map("goal_type")
  goalValue     Int         @map("goal_value")
  startDate     DateTime    @map("start_date") @db.Date
  targetDate    DateTime    @map("target_date") @db.Date
  currentStreak Int         @default(0) @map("current_streak")
  longestStreak Int         @default(0) @map("longest_streak")
  mercyDayUsed  Boolean     @default(false) @map("mercy_day_used")
  lastMercyWeek String?     @map("last_mercy_week") @db.VarChar(50)
  isComplete    Boolean     @default(false) @map("is_complete")
  isActive      Boolean     @default(true) @map("is_active")
  readerName    String?     @map("reader_name")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at")

  days NiyyahJourneyDay[]
  gift JourneyGift?

  @@map("niyyah_journeys")
}

model NiyyahJourneyDay {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  journeyId  String   @map("journey_id") @db.Uuid
  date       DateTime @db.Date
  versesRead Int      @map("verses_read")
  surahRange String   @map("surah_range")
  startKey   String   @map("start_key") @db.VarChar(50)
  endKey     String   @map("end_key") @db.VarChar(50)
  reflection String?
  isMercy    Boolean  @default(false) @map("is_mercy")
  createdAt  DateTime @default(now()) @map("created_at")

  journey NiyyahJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@map("niyyah_journey_days")
}

model JourneyGift {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  journeyId     String   @unique @map("journey_id") @db.Uuid
  imageMime     String   @default("image/png") @map("image_mime") @db.VarChar(60)
  imageBytes    Bytes    @map("image_bytes")
  recipientName String   @map("recipient_name") @db.VarChar(255)
  generatedAt   DateTime @default(now()) @map("generated_at")

  journey NiyyahJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@map("journey_gifts")
}

model ReadingSession {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.VarChar(255)
  date          DateTime @db.Date
  surahId       Int      @map("surah_id")
  versesRead    Int      @default(0) @map("verses_read")
  minutesRead   Int      @default(0) @map("minutes_read")
  pagesRead     Int      @default(0) @map("pages_read")
  firstVerseKey String?  @map("first_verse_key") @db.VarChar(50)
  lastVerseKey  String?  @map("last_verse_key") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  // Atomic upsert key — prevents lost updates when several
  // verse-mark-complete requests land at once for the same surah/day.
  @@unique([userId, date, surahId])
  @@index([userId, date])
  @@map("reading_sessions")
}

// Bookmarks, collections, notes, goals, and verse-completion tracking
// are now first-party tables (replacing the inconsistent QF SDK paths).

model Bookmark {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.VarChar(255)
  verseKey    String   @map("verse_key") @db.VarChar(20)
  surahId     Int      @map("surah_id")
  verseNumber Int      @map("verse_number")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([userId, verseKey])
  @@index([userId])
  @@map("bookmarks")
}

model Collection {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.VarChar(255)
  name          String   @db.VarChar(255)
  coverImageUrl String?  @map("cover_image_url") @db.VarChar(1024)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  items CollectionItem[]

  @@index([userId])
  @@map("collections")
}

model CollectionItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collectionId String   @map("collection_id") @db.Uuid
  verseKey     String   @map("verse_key") @db.VarChar(20)
  addedAt      DateTime @default(now()) @map("added_at")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, verseKey])
  @@index([collectionId])
  @@map("collection_items")
}

model Note {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.VarChar(255)
  verseKey  String   @map("verse_key") @db.VarChar(20)
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, verseKey])
  @@map("notes")
}

model TadabburCircle {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  verseKey        String   @map("verse_key") @db.VarChar(20)
  hijriMonth      String   @map("hijri_month") @db.VarChar(50)
  hijriYear       Int      @map("hijri_year")
  startDate       DateTime @map("start_date") @db.Date
  endDate         DateTime @map("end_date") @db.Date
  isActive        Boolean  @default(true) @map("is_active")
  totalDays       Int      @default(15) @map("total_days")
  participantCount Int     @default(0) @map("participant_count")
  createdAt       DateTime @default(now()) @map("created_at")

  userProgress TadabburUserProgress[]
  cachedContent TadabburCachedContent[]

  @@unique([verseKey, hijriYear])
  @@map("tadabbur_circles")
}

model TadabburCachedContent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  circleId  String   @map("circle_id") @db.Uuid
  day       Int
  angleType String   @map("angle_type") @db.VarChar(50)
  content   String   @db.Text
  sources   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  circle TadabburCircle @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@unique([circleId, day, angleType])
  @@index([circleId])
  @@map("tadabbur_cached_content")
}

model TadabburUserProgress {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.VarChar(255)
  circleId          String    @map("circle_id") @db.Uuid
  currentDay        Int       @default(1) @map("current_day")
  completedDays     Int[]     @default([]) @map("completed_days")
  lastCompletedAt   DateTime? @map("last_completed_at")
  startedDate       DateTime  @map("started_date") @db.Date
  isComplete        Boolean   @default(false) @map("is_complete")
  completedAt       DateTime? @map("completed_at")
  personalStatement String?   @map("personal_statement")
  verseMemorised    Boolean   @default(false) @map("verse_memorised")
  duaLearned        Boolean   @default(false) @map("dua_learned")
  timerEnabled      Boolean   @default(true) @map("timer_enabled")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  circle   TadabburCircle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  journals TadabburJournal[]
  actions  TadabburAction[]
  certificate TadabburCertificate?

  @@unique([userId, circleId])
  @@index([userId])
  @@map("tadabbur_user_progress")
}

model TadabburJournal {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  progressId String   @map("progress_id") @db.Uuid
  day        Int
  content    String
  isPublic   Boolean  @default(false) @map("is_public")
  region     String?  @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  progress TadabburUserProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@unique([progressId, day])
  @@index([progressId])
  @@map("tadabbur_journals")
}

model TadabburAction {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  progressId String   @map("progress_id") @db.Uuid
  day        Int
  completed  Boolean  @default(false)
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  progress TadabburUserProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@unique([progressId, day])
  @@index([progressId])
  @@map("tadabbur_actions")
}

model TadabburCertificate {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.VarChar(255)
  progressId      String   @unique @map("progress_id") @db.Uuid
  circleId        String   @map("circle_id") @db.Uuid
  verseKey        String   @map("verse_key") @db.VarChar(20)
  completedAt     DateTime @map("completed_at")
  certificateText String   @map("certificate_text") @db.Text
  shareableUrl    String?  @map("shareable_url") @db.VarChar(500)
  createdAt       DateTime @default(now()) @map("created_at")

  progress TadabburUserProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("tadabbur_certificates")
}

model Goal {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.VarChar(255)
  period       String   @db.VarChar(20) // "daily" | "weekly"
  type         String   @db.VarChar(20) // "PAGES" | "VERSES" | "TIME"
  targetAmount Int      @map("target_amount")
  mushafId     Int?     @map("mushaf_id")
  category     String?  @db.VarChar(40)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  progress GoalProgress[]

  @@index([userId])
  @@map("goals")
}

model GoalProgress {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  goalId        String   @map("goal_id") @db.Uuid
  userId        String   @map("user_id") @db.VarChar(255)
  date          DateTime @db.Date
  versesRead    Int      @default(0) @map("verses_read")
  minutesRead   Int      @default(0) @map("minutes_read")
  pagesRead     Int      @default(0) @map("pages_read")
  targetMet     Boolean  @default(false) @map("target_met")
  currentStreak Int      @default(0) @map("current_streak")
  longestStreak Int      @default(0) @map("longest_streak")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, date])
  @@index([userId, date])
  @@map("goal_progress")
}

// One row per (user, verse, day). Time-spent is wall-clock between when the
// verse was first focused and when the user explicitly marked it complete,
// minus any time the tab was hidden.
model VerseCompletion {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.VarChar(255)
  verseKey    String   @map("verse_key") @db.VarChar(20)
  surahId     Int      @map("surah_id")
  verseNumber Int      @map("verse_number")
  timeSpentMs Int      @default(0) @map("time_spent_ms")
  sessionDate DateTime @map("session_date") @db.Date
  completedAt DateTime @default(now()) @map("completed_at")

  @@unique([userId, verseKey, sessionDate])
  @@index([userId, sessionDate])
  @@map("verse_completions")
}
